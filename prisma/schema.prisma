generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  releaseYear Int
  genre       String
  rating      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
